# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase Admin SDK credential
erp-mediator-firebase-adminsdk-*.json

# Firebase Service Account Key — jangan pernah commit file ini
scripts/serviceAccountKey.json

# Claude Code internal memory — bukan bagian dari source project
.claude/

# Environment files
.env*.local
.env.development.local
.env.production.local

# Firebase service account keys
firebase-dev-service-account.json
firebase-prod-service-account.json
*-service-account.json